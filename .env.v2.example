# ===== V2 ENV EXAMPLE =====
# Copy to .env.v2 and set real secrets

DB_PASSWORD=change-this-v2-db-password
SECRET_KEY=change-this-v2-secret

# Public URLs
FRONTEND_ORIGIN=http://localhost:5175
API_BASE_URL=http://localhost:8100

# Ports
V2_DB_PORT=5435
V2_BACKEND_PORT=8100
V2_FRONTEND_PORT=5175

# App
V2_DATABASE_NAME=ces_sale_operation_v2
V2_ENVIRONMENT=production
